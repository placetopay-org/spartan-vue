{
  "name": "@placetopay/spartan-vue",
  "version": "3.0.0",
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "description": "spartan vue lib",
  "license": "MIT",
  "module": "./dist/components/index.js",
  "types": "./dist/components/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist/*",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./locales": {
      "types": "./dist/locales/index.d.ts",
      "import": "./dist/locales/index.js"
    },
    "./i18n": {
      "types": "./dist/expose/i18n.d.ts",
      "import": "./dist/expose/i18n.js"
    },
    "./styles.css": "./dist/styles.css",
    "./styles/spartan-vue.css": "./dist/styles/spartan-vue.css",
    "./styles/main.css": "./dist/styles/main.css",
    "./styles/fonts.css": "./dist/styles/fonts.css",
    "./styles/plugin.css": "./dist/styles/plugin.css"
  },
  "repository": {
    "url": "git+https://github.com/placetopay-org/spartan-vue.git"
  },
  "scripts": {
    "dev": "nuxt dev --cwd docs",
    "build": "vite build && pnpm run build:types && rollup -c && node scripts/copyLocales.js && node scripts/copyCss.js && node scripts/sanitizeBuild.js",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly --noEmit false --outDir dist/types",
    "build:rollup": "rollup -c",
    "docs:dev": "nuxt dev --cwd docs",
    "docs:build": "nuxt build --cwd docs",
    "docs:generate": "nuxt generate --cwd docs",
    "docs:preview": "nuxt preview --cwd docs",
    "docs:deploy": "cd docs && wrangler deploy",
    "test": "vitest watch --ui --coverage",
    "test:run": "vitest run --coverage --coverage.reporter=text",
    "test:ci": "vitest run --coverage",
    "test:quick": "vitest run",
    "typecheck": "vue-tsc --noEmit",
    "check:deps": "node scripts/checkPhantomDeps.js",
    "check:locales": "node scripts/checkLocales.js",
    "check:status": "node scripts/checkComponentStatus.js",
    "status:sync": "node scripts/syncComponentStatus.js",
    "status:check": "node scripts/syncComponentStatus.js --check",
    "verify": "pnpm run typecheck && pnpm run check:deps && pnpm run check:locales && pnpm run check:status && pnpm run lint:check && pnpm run format:check && pnpm run test:ci && pnpm run status:check && pnpm run build",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "foli": "pnpm run format && pnpm run lint",
    "foli:check": "pnpm run format:check && pnpm run lint:check",
    "release": "release-it"
  },
  "dependencies": {
    "@tailwindcss/forms": "0.5.11",
    "vue-sonner": "2.0.9"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-i18n": "^11.0.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@floating-ui/vue": "2.0.1",
    "@headlessui/vue": "1.7.23",
    "@heroicons/vue": "2.2.0",
    "@nuxt/fonts": "0.14.0",
    "@nuxt/ui": "4.10.0",
    "@placetopay/flagicons-vue": "0.1.0",
    "@placetopay/iconsax-vue": "1.0.0",
    "@primevue/icons": "4.5.4",
    "@release-it/keep-a-changelog": "^7.1.0",
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-terser": "1.0.0",
    "@tailwindcss/typography": "0.5.20",
    "@tailwindcss/vite": "4.3.3",
    "@tanstack/vue-table": "8.21.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "@testing-library/vue": "8.1.0",
    "@types/big.js": "7.0.0",
    "@types/node": "26.1.1",
    "@vitejs/plugin-vue": "6.0.8",
    "@vitest/coverage-istanbul": "4.1.10",
    "@vitest/ui": "4.1.10",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "@vueuse/core": "14.3.0",
    "autoprefixer": "10.5.4",
    "better-sqlite3": "12.11.1",
    "big.js": "7.0.1",
    "class-variance-authority": "0.7.1",
    "dayjs": "1.11.21",
    "docus": "5.12.3",
    "echarts": "6.1.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "imask": "7.6.1",
    "jsdom": "29.1.1",
    "nuxt": "4.4.8",
    "postcss": "8.5.19",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "primevue": "4.5.4",
    "release-it": "^20.2.1",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "rollup-plugin-esbuild": "6.2.1",
    "rollup-plugin-postcss": "4.0.2",
    "rollup-plugin-vue": "6.0.0",
    "tailwind-merge": "3.6.0",
    "tailwindcss": "4.3.3",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vite-svg-loader": "5.1.1",
    "vitest": "4.1.10",
    "vue": "3.5.40",
    "vue-currency-input": "3.2.2",
    "vue-echarts": "8.0.1",
    "vue-i18n": "11.4.6",
    "vue-tsc": "3.3.7",
    "wrangler": "4.111.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "sqlite3",
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "vue-demi"
    ]
  },
  "bugs": {
    "url": "https://github.com/placetopay-org/spartan-vue/issues"
  },
  "homepage": "https://github.com/placetopay-org/spartan-vue#readme",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
