{
    "git": {
        "commitMessage": "chore(release): v${version}",
        "tagName": "${version}",
        "push": true,
        "requireBranch": ["main", "2.x"]
    },
    "npm": {
        "publish": true,
        "skipChecks": true
    },
    "github": {
        "release": true,
        "releaseName": "v${version}"
    },
    "plugins": {
        "@release-it/keep-a-changelog": {
            "filename": "CHANGELOG.md",
            "addUnreleased": true
        }
    },
    "hooks": {
        "before:init": ["pnpm run test:ci"],
        "after:bump": ["pnpm run build"]
    }
}
