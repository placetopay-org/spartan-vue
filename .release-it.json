{
    "git": {
        "commitMessage": "chore(release): v${version}",
        "tagName": "${version}",
        "push": true,
        "requireBranch": ["main", "2.x"]
    },
    "npm": {
        "publish": true
    },
    "github": {
        "release": true,
        "releaseName": "v${version}"
    },
    "plugins": {
        "@release-it/keep-a-changelog": {
            "filename": "CHANGELOG.md",
            "addUnreleased": true
        }
    },
    "hooks": {
        "before:init": [
            "sh -c 'if [ \"$CI\" = \"true\" ]; then echo \"Verified by the CI workflow; skipping local checks.\"; else pnpm run verify; fi'"
        ],
        "after:bump": ["pnpm run build", "pnpm dlx publint"]
    }
}
