{
    "git": {
        "commitMessage": "chore(release): v${version}",
        "tagName": "${version}",
        "push": true,
        "requireBranch": ["main", "2.x"]
    },
    "npm": {
        "publish": true,
        "skipChecks": true
    },
    "github": {
        "release": true,
        "releaseName": "v${version}"
    },
    "plugins": {
        "@release-it/keep-a-changelog": {
            "filename": "CHANGELOG.md",
            "addUnreleased": true
        }
    },
    "hooks": {
        "before:init": [
            "pnpm run typecheck",
            "pnpm run check:deps",
            "pnpm run lint:check",
            "pnpm run format:check",
            "pnpm run test:ci",
            "pnpm run build"
        ],
        "after:bump": ["pnpm run build", "pnpm dlx publint"]
    }
}
